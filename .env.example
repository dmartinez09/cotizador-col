# ============================================================
# Point Colombia Cotizador — Variables de Entorno
# Copie este archivo como .env y configure los valores.
# ============================================================

# --- Node.js ---
NODE_ENV=development
PORT=3000

# --- Base de datos MySQL ---
DATABASE_URL=mysql://usuario:contraseña@localhost:3306/cotizador_colombia

# --- JWT / Cookies ---
# Secreto para firmar tokens JWT de sesión (mínimo 32 caracteres)
JWT_SECRET=cambiar-este-secreto-por-uno-seguro-y-largo

# --- OAuth (opcional — para login con Manus OAuth Portal) ---
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# --- Azure Blob Storage ---
# OBLIGATORIO en producción (NODE_ENV=production).
# En desarrollo, si no se configura, los PDFs se guardan en ./uploads/pdfs/ localmente.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=cotizador-pdfs
# Fallback (legacy): AZURE_STORAGE_CONTAINER=cotizador-pdfs

# --- Seed script (opcional) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# --- Forge API (usado internamente por Manus, no necesario en producción propia) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
